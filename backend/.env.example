# MySQL Configuration
MYSQL_DB=chatapp
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# JWT Secret (cambia esto en producción)
JWT_SECRET=super_secret_key_change_me_in_production_123456789

# WebSocket Server
HOST=0.0.0.0
PORT=8765

# SSL Certificates (paths relative to backend folder)
SSL_CERT=../certs/local.pem
SSL_KEY=../certs/local-key.pem

# Debug (1 para activar logs de desconexión)
LOG_WS_DISCONNECTS=0
